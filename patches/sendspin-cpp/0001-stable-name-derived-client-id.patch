+// Derive a stable, unique client id from the friendly name so each device is
+// a distinct Music Assistant player (the stock example hardcoded one shared
+// id, which collapsed every device onto the same MA player/entity).
+static std::string slugify(const std::string& s) {
+    std::string out;
+    for (char c : s) {
+        unsigned char uc = static_cast<unsigned char>(c);
+        if (std::isalnum(uc)) out += static_cast<char>(std::tolower(uc));
+        else if (!out.empty() && out.back() != '-') out += '-';
+    }
+    while (!out.empty() && out.back() == '-') out.pop_back();
+    return out.empty() ? "sendspin-cpp" : out;
+}
