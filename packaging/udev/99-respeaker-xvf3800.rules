# Stable naming + permissions for the reSpeaker XVF3800 USB 4-mic array.
#
# Seeed reSpeaker XVF3800 USB 4-mic array — vendor:product 2886:001a
# (verified on hardware 2026-06-09). Grants non-root access to the USB control
# endpoint so xvf_host can run without sudo.
#
# Installed to /etc/udev/rules.d/ by install.sh (Phase 8). Reload with:
#   sudo udevadm control --reload-rules && sudo udevadm trigger --attr-match=idVendor=2886

SUBSYSTEM=="usb", ATTRS{idVendor}=="2886", ATTRS{idProduct}=="001a", \
    MODE="0666", GROUP="plugdev", SYMLINK+="respeaker-xvf3800"
